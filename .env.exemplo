METAJI_SESSION_PASSWORD=abc123
METAJI_SESSION_SERVER_PORT=3456
#
# Reinicio automatico das sessoes (apenas multiSession).
# Valor em minutos. Ex: 30 = reiniciar cada 30 minutos.
# 0 ou vazio = desabilitado.
METAJI_SESSIONS_RESTART_MINUTES=0
#
# Forca o uso da versao "src" do multiSessionManager (evita dist ofuscada).
METAJI_FORCE_MULTISESSION_SRC=1

#
# Limite maximo de sessoes ativas (conectadas + pendentes/QR).
# 0 ou vazio = sem limite.
METAJI_SESSIONS_MAX=20